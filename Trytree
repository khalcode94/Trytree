<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nafe3 Store | نافع ستور</title>
    
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* --- كود التصميم والتأثيرات البصرية (CSS) --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Cairo', sans-serif;
        }

        body {
            background-color: #0c0c0c;
            /* استبدل 469171.jpg باسم صورة خلفيتك إذا قمت برفعها على GitHub */
            background-image: url('469171.jpg'); 
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            color: #ffffff;
            overflow-x: hidden;
        }

        /* طبقة حماية داكنة وتأثير زجاجي */
        .background-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.8), rgba(15, 15, 15, 0.7));
            z-index: 1;
        }

        .container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 450px;
            padding: 50px 20px;
            text-align: center;
        }

        /* تصميم رأس الصفحة */
        .profile-header {
            margin-bottom: 35px;
            animation: fadeInDown 1s ease-out;
        }

        .store-name {
            font-size: 2.6rem;
            color: #a3e635; /* اللون الأخضر الليموني الجذاب */
            font-weight: 700;
            margin-bottom: 5px;
            text-shadow: 0 0 15px rgba(163, 230, 53, 0.2);
        }

        .store-bio {
            font-size: 0.9rem;
            color: #b3b3b3;
        }

        /* حاوية الأزرار */
        .links-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* تصميم الأزرار الذكية */
        .link-btn {
            display: flex;
            align-items: center;
            padding: 14px 22px;
            border-radius: 40px;
            text-decoration: none;
            color: white;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.4);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0; /* يبدأ مخفي لعمل حركة الظهور التتابعي */
            animation: fadeInUp 0.6s ease-out forwards;
        }

        /* تأثيرات الحركة عند تمرير الماوس */
        .link-btn:hover {
            transform: translateY(-4px) scale(1.01);
            box-shadow: 0 8px 25px rgba(163, 230, 53, 0.2);
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(163, 230, 53, 0.4);
        }

        /* أيقونات الأزرار */
        .icon {
            font-size: 1.3rem;
            margin-left: 15px;
            width: 30px;
            text-align: center;
            transition: transform 0.3s ease;
        }
        
        .link-btn:hover .icon {
            transform: rotate(10deg) scale(1.1);
        }

        /* الصور المستدعاة من الشيت داخل الزر */
        .btn-img {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            margin-left: 15px;
            object-fit: cover;
            border: 2px solid #a3e635;
        }

        /* نصوص الأزرار */
        .btn-text {
            display: flex;
            flex-direction: column;
            text-align: right;
            flex-grow: 1;
        }

        .btn-text .title {
            font-size: 1.05rem;
            font-weight: 700;
        }

        .btn-text .subtitle {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            margin-top: 2px;
        }

        /* ألوان التدرج للأزرار */
        .btn-purple { background: linear-gradient(135deg, rgba(109, 40, 217, 0.8), rgba(76, 29, 149, 0.8)); }
        .btn-blue   { background: linear-gradient(135deg, rgba(29, 78, 216, 0.8), rgba(30, 58, 138, 0.8)); }
        .btn-green  { background: linear-gradient(135deg, rgba(5, 150, 105, 0.8), rgba(6, 78, 59, 0.8)); }
        .btn-dark   { background: linear-gradient(135deg, rgba(55, 65, 81, 0.8), rgba(17, 24, 27, 0.8)); }

        .loading, .error-msg {
            color: #a3e635;
            font-size: 1.1rem;
            padding: 30px;
            animation: pulse 1.5s infinite;
        }

        /* الكي-فريمز للحركات */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulse {
            0% { opacity: 0.6; }
            50% { opacity: 1; }
            100% { opacity: 0.6; }
        }
    </style>
</head>
<body>

    <div class="background-overlay"></div>

    <div class="container">
        <header class="profile-header">
            <h1 class="store-name">نافع ستور</h1>
            <p class="store-bio">Nafe3.Store For Mobile & Internet Services</p>
        </header>

        <main class="links-list" id="links-container">
            <div class="loading"><i class="fa-solid fa-circle-notch fa-spin"></i> جاري تحميل الخدمات والعروض...</div>
        </main>
    </div>

    <script>
        // ==========================================
        // خطوة السيت أب: ضع معرف جدول البيانات الخاص بك هنا
        // ==========================================
const SPREADSHEET_ID = 1z1iYsSmwvCmUIGBoF8Wo9ZbmOafXebIa3krxa7wn0eM';        
        const url = `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:json`;

        async function fetchLinks() {
            try {
                const response = await fetch(url);
                const text = await response.text();
                
                // تنظيف وفك شفرة البيانات القادمة من جوجل شيت تلقائياً
                const jsonData = JSON.parse(text.substr(47).slice(0, -2));
                const rows = jsonData.table.rows;
                
                const container = document.getElementById('links-container');
                container.innerHTML = ''; // إزالة كلمة جاري التحميل

                const today = new Date();
                today.setHours(0, 0, 0, 0);

                let delay = 0; // متغير لعمل ظهور تتابعي جميل للأزرار

                rows.forEach(row => {
                    // السيت أب التلقائي: قراءة الأعمدة بناءً على ترتيبها في الجدول
                    const title = row.c[0] ? row.c[0].v : '';
                    const subtitle = row.c[1] ? row.c[1].v : '';
                    const linkUrl = row.c[2] ? row.c[2].v : '#';
                    const colorClass = row.c[3] ? row.c[3].v : 'purple';
                    const iconName = row.c[4] ? row.c[4].v : 'fa-link';
                    const startDateStr = row.c[5] ? row.c[5].v : null;
                    const endDateStr = row.c[6] ? row.c[6].v : null;
                    const imageUrl = row.c[7] ? row.c[7].v : null;

                    // نظام فحص جدولة التاريخ التلقائي
                    let shouldShow = true;

                    if (startDateStr) {
                        // تحويل صيغة تاريخ جوجل شيت إلى صيغة يفهمها المتصفح
                        const startDate = new Date(startDateStr);
                        startDate.setHours(0, 0, 0, 0);
                        if (today < startDate) shouldShow = false;
                    }

                    if (endDateStr) {
                        const endDate = new Date(endDateStr);
                        endDate.setHours(0, 0, 0, 0);
                        if (today > endDate) shouldShow = false;
                    }

                    // إذا نجح الزر في الفحص ولم ينتهِ تاريخه، نقوم بعرضه وحركته
                    if (shouldShow && title) {
                        delay += 0.15; // زيادة التوقيت لكل زر ليظهر بعد الذي قبله
                        
                        // اختيار إما أيقونة كلاسيكية أو الصورة المرفوعة من الجدول
                        const mediaHTML = imageUrl 
                            ? `<img src="${imageUrl}" class="btn-img" alt="${title}">` 
                            : `<i class="fa-solid ${iconName} icon"></i>`;

                        const btnHTML = `
                            <a href="${linkUrl}" class="link-btn btn-${colorClass}" target="_blank" style="animation-delay: ${delay}s">
                                ${mediaHTML}
                                <div class="btn-text">
                                    <span class="title">${title}</span>
                                    ${subtitle ? `<span class="subtitle">${subtitle}</span>` : ''}
                                </div>
                            </a>
                        `;
                        container.innerHTML += btnHTML;
                    }
                });

                // في حال عدم وجود عروض مفعلة اليوم
                if (container.innerHTML === '') {
                    container.innerHTML = '<div class="error-msg">تابعونا قريباً لمعرفة أحدث خدماتنا وعروضنا الحصرية!</div>';
                }

            } catch (error) {
                console.error('Error:', error);
                document.getElementById('links-container').innerHTML = '<div class="error-msg">عذراً، تعذر تحديث البيانات حالياً.</div>';
            }
        }

        // تشغيل النظام تلقائياً
        fetchLinks();
    </script>
</body>
</html>
